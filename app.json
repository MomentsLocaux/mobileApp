{
  "expo": {
    "name": "Moments Locaux",
    "slug": "moments-locaux",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "momentslocaux",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "extra": {},
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.momentslocs.app"
    },
    "android": {
      "package": "com.momentslocs.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "@rnmapbox/maps"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
