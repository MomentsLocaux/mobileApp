# Moments Locaux — Mobile (Expo)
# Cross-repo env guide: Moments-Locaux-Scrapper/docs/ENV_CHECKLIST.md
#
# Setup: cp .env.example .env
# Security: EXPO_PUBLIC_* values are embedded in the app bundle — never use for secrets

# --- Required (Supabase — same project as admin / scrapper) ---
# Same URL as VITE_SUPABASE_URL (admin) and SUPABASE_URL (scrapper)
EXPO_PUBLIC_SUPABASE_URL=
# Same anon key as VITE_SUPABASE_ANON_KEY (admin)
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Required (Mapbox map UI) ---
EXPO_PUBLIC_MAPBOX_TOKEN=

# --- Recommended ---
EXPO_PUBLIC_SENTRY_DSN=
EAS_PROJECT_ID=

# --- Storage buckets (defaults shown) ---
EXPO_PUBLIC_SUPABASE_AVATAR_BUCKET=avatar
EXPO_PUBLIC_SUPABASE_EVENT_COVER_BUCKET=event-media

# --- Optional (deep links / sharing) ---
EXPO_PUBLIC_EVENT_QR_BASE_URL=https://momentslocaux.app/events
EXPO_PUBLIC_APP_SHARE_URL=

# --- Optional (debug) ---
# EXPO_PUBLIC_MAP_SHEET_PERF_TRACE=1

# --- Native build / download tokens (local or CI — not EXPO_PUBLIC_*) ---
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=
MAPBOX_DOWNLOADS_TOKEN=

# --- Server/admin only (scripts, CI, Edge Functions — never EXPO_PUBLIC_*) ---
SUPABASE_SERVICE_ROLE_KEY=
