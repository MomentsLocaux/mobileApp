# Local default = DEV. For UAT: copy .env.uat.example → .env.uat (gitignored).
EXPO_PUBLIC_APP_ENV=dev

# Public mobile runtime values. These can be embedded in the Expo app bundle.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_MAPBOX_TOKEN=
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SUPABASE_AVATAR_BUCKET=avatar
EXPO_PUBLIC_SUPABASE_EVENT_COVER_BUCKET=event-media

# Discovery Engine (flags — restart Metro after change)
EXPO_PUBLIC_DISCOVERY_ENABLED=false
EXPO_PUBLIC_DISCOVERY_CAPTURE_ENABLED=false

# Contests (post-MVP — restart Metro after change)
EXPO_PUBLIC_FEATURE_CONTESTS=false

# Habitué / Lumo gamification (post-MVP — server flag app_config.gamification_enabled)
EXPO_PUBLIC_GAMIFICATION_ENABLED=false

# Native build/download tokens. Keep local or in CI secrets; do not expose with EXPO_PUBLIC_*.
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=
MAPBOX_DOWNLOADS_TOKEN=

# Required for Expo push tokens (eas init). Never commit the real value if sensitive.
EAS_PROJECT_ID=

# Server/admin only. Keep out of Expo public config and never prefix with EXPO_PUBLIC_.
# Required only for local admin scripts or Supabase Edge Function deployment/runtime secrets.
SUPABASE_SERVICE_ROLE_KEY=

# QR code share/check-in landing (web HTTPS) used inside the QR image.
# Leave empty for now; app uses a placeholder base URL locally.
EXPO_PUBLIC_EVENT_QR_WEB_BASE_URL=

# For testing only: when true, the QR contains a custom scheme link
# (opens the app if installed). When false, the QR contains an HTTPS link
# intended for Universal/App Links (real site config later).
EXPO_PUBLIC_EVENT_QR_USE_APP_SCHEME=false

# Optional override of the scheme base used when EXPO_PUBLIC_EVENT_QR_USE_APP_SCHEME=true.
EXPO_PUBLIC_EVENT_QR_APP_BASE_URL=momentslocaux://events
